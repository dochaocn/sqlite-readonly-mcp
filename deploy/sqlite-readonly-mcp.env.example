# 复制为 /etc/sqlite-readonly-mcp.env 并 chmod 600；字段与程序 loadConfig() 一致

# 必填：SQLite 数据库文件绝对路径（只读打开，须已存在）
SQLITE_PATH=/var/lib/app/data.sqlite
# 必填：HTTP Bearer 令牌（客户端 Authorization: Bearer …）
BEARER_TOKEN=
# 监听地址；反代本机用 127.0.0.1，直接对外可 0.0.0.0
HOST=127.0.0.1
# 监听端口（与 nginx upstream 一致）
PORT=3333
# 可选：允许的 Host 头，逗号分隔；须含对外域名，否则 MCP Host 校验会拒绝
ALLOWED_HOSTS=mcp.example.com,127.0.0.1,localhost
# 单次 sqlite_query 返回行数上限
SQLITE_MAX_ROWS=5000
